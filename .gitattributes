# Normalize text files (consistent LF endings)
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf
*.yml  text eol=lf
*.md   text eol=lf

# Treat images/binaries correctly
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.pdf  binary